# =======================================================================
# .env.example — Modelo de variáveis de ambiente do Oficina ERP
# -----------------------------------------------------------------------
# Copie este arquivo para ".env" e preencha os valores.
#   cp .env.example .env
#
# ATENÇÃO: o ".env" (com valores reais) NÃO deve ir para o Git.
# No Railway, defina estas variáveis na aba "Variables" do serviço do app
# (não é preciso criar arquivo .env lá).
# =======================================================================

# -----------------------------------------------------------------------
# OBRIGATÓRIAS
# -----------------------------------------------------------------------

# Chave usada para assinar o cookie de sessão (login).
# Gere uma aleatória com:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-aleatoria-e-longa

# Conexão com o PostgreSQL.
# - No Railway: use uma Reference Variable -> ${{Postgres.DATABASE_URL}}
# - Local/externo: cole a connection string completa no formato abaixo.
# Se esta variável existir, o sistema entra em modo PostgreSQL automaticamente.
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco


# -----------------------------------------------------------------------
# OPCIONAIS (o sistema funciona sem elas)
# -----------------------------------------------------------------------

# Motor do banco. Deixe em branco para detecção automática:
#   - com DATABASE_URL definida  -> postgres
#   - sem DATABASE_URL           -> sqlite (arquivo local database/banco.db)
# Só defina se quiser forçar manualmente. Valores: sqlite | postgres
# DB_ENGINE=postgres

# Porta do servidor de desenvolvimento (python server.py). Padrão: 5000.
# No Railway é injetada automaticamente — NÃO defina lá.
# PORT=5000

# Modo debug do servidor de desenvolvimento (1 = ligado, 0 = desligado).
# Só afeta "python server.py"; em produção (gunicorn) é ignorado.
# FLASK_DEBUG=1

# Alternativa à DATABASE_URL: variáveis separadas do PostgreSQL.
# Usadas apenas como fallback, quando NÃO houver DATABASE_URL.
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=oficina
# PGUSER=postgres
# PGPASSWORD=
